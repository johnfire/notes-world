# mail-mcp configuration — see README.md for the full picture.

# --- Server / OAuth ---
MAIL_MCP_PORT=3003
MAIL_MCP_BASE_URL=https://mcp.mail.christopherrehm.de
MAIL_MCP_OAUTH_CLIENT_ID=mail-mcp
MAIL_MCP_JWT_SECRET=replace-with-a-long-random-string
MAIL_MCP_API_KEY=mm_replace-with-a-long-random-string
# Persist refresh tokens across restarts (a docker volume in prod). Leave unset in dev.
MAIL_MCP_STORE_PATH=/data/oauth-store.json

# --- IMAP (Dovecot) ---
# Login uses the dedicated master user: <mailbox>*<master-user>
IMAP_HOST=mail.christopherrehm.de
IMAP_PORT=993
IMAP_LOGIN=contact@christopherrehm.de*mcp-mail
IMAP_PASSWORD=replace-with-the-master-user-password

# --- Identity / send-as ---
# The mailbox we operate on (default From, and "self" for replies).
MAILBOX_ADDRESS=contact@christopherrehm.de
# Comma-separated identities a draft may be sent as. The primary is added
# automatically if omitted.
MAIL_MCP_ALLOWED_FROM=contact@christopherrehm.de,christopher@leguilde.art,contact@leguilde.art,contact@tandkcybernetics.net
