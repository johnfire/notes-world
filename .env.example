# Copy to .env and fill in values

# PostgreSQL
POSTGRES_PASSWORD=change_me_strong_password

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_64_byte_hex_string

# Domain for Nginx + CORS (production only)
NGINX_HOST=notes.yourdomain.com

# Timezone for backup rotation
TZ=Europe/Berlin

# Bug reporting — GitHub token for auto-filing issues
# Create a fine-grained PAT with "Issues: Read and Write" on this repo
# Repo: johnfire/notes-world (override with GITHUB_REPO if needed)
GITHUB_TOKEN=ghp_your_token_here
# GITHUB_REPO=johnfire/notes-world

# Stripe billing
# Create Products + Prices in Stripe Dashboard, then fill in the Price IDs
# Webhook: register https://yourdomain.com/api/billing/webhook in Stripe Dashboard
# Events: customer.subscription.created, customer.subscription.updated, customer.subscription.deleted
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_MONTHLY_ID=price_...
STRIPE_PRICE_ANNUAL_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
APP_URL=https://notes-world.christopherrehm.de

# Local dev overrides (not needed in production docker-compose)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=notes_world
POSTGRES_USER=notes_world
PORT=3001
NODE_ENV=development
